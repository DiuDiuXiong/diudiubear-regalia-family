-- --------------------------------------------------------------------------
-- Required invisible barrel core. ZERO Sievert calculates brake/suppressor
-- placement from the installed barrel, so a valid barrel mod must exist.
-- --------------------------------------------------------------------------
WeaponModCreate("wz_ddb_regalia_barrel_core","barrel",0,0,0,0,0,false,["wz_ddb_regalia","wz_ddb_regalia_prism"]);
ItemSetName("wz_ddb_regalia_barrel_core","Regalia Internal Barrel");
ItemSetDescription("wz_ddb_regalia_barrel_core","A sealed internal barrel core required by the Regalia muzzle-device interface.");
ItemSetSpriteInventory("wz_ddb_regalia_barrel_core","wz_ddb_regalia_barrel_core_inventory");
ItemSetSpriteIngame("wz_ddb_regalia_barrel_core","wz_ddb_regalia_barrel_core_ingame");
ItemSetPriceValue("wz_ddb_regalia_barrel_core",0);
ItemSetWeight("wz_ddb_regalia_barrel_core",0.0);
ItemSetStackLimit("wz_ddb_regalia_barrel_core",1);

-- --------------------------------------------------------------------------
-- Shared original-colour muzzle devices.
-- Compact and Standard are normal brake-type muzzle devices.
-- Grand is the only true silencer and is configured separately in regalia_sounds.script.
-- --------------------------------------------------------------------------
WeaponModCreate("wz_ddb_regalia_front_compact","brake",0,1,1,-2,0,false,["wz_ddb_regalia","wz_ddb_regalia_prism"]);
