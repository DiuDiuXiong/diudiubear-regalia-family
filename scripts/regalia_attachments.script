-- Regalia-only attachments.
-- WeaponModCreate layout:
-- id, mod type, accuracy, damage, ergonomics, recoil, reload speed,
-- scope optic, compatible weapon IDs, optional attachment slots.
-- Item prices are configured separately with ItemSetPriceValue.

-- --------------------------------------------------------------------------
-- Sprites: both inventory and in-game sprites reference the cropped files.
-- Each slot uses one shared crop rectangle so every variant aligns identically.
-- Every cropped attachment is at most 14x11, so it occupies one inventory grid cell.
-- --------------------------------------------------------------------------
SpriteLoad("wz_ddb_regalia_stock_compact_inventory","items/inventory/regalia_stock_compact.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_compact_ingame","items/cropped/regalia_stock_compact.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_standard_inventory","items/inventory/regalia_stock_standard.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_standard_ingame","items/cropped/regalia_stock_standard.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_grand_inventory","items/inventory/regalia_stock_grand.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_grand_ingame","items/cropped/regalia_stock_grand.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_compact_prism_inventory","items/inventory/regalia_stock_compact_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_compact_prism_ingame","items/cropped/regalia_stock_compact_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_standard_prism_inventory","items/inventory/regalia_stock_standard_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_standard_prism_ingame","items/cropped/regalia_stock_standard_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_grand_prism_inventory","items/inventory/regalia_stock_grand_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_stock_grand_prism_ingame","items/cropped/regalia_stock_grand_prism.png",1,0,0,0);

SpriteLoad("wz_ddb_regalia_grip_standard_inventory","items/inventory/regalia_grip_standard.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_standard_ingame","items/cropped/regalia_grip_standard.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_grand_inventory","items/inventory/regalia_grip_grand.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_grand_ingame","items/cropped/regalia_grip_grand.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_standard_prism_inventory","items/inventory/regalia_grip_standard_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_standard_prism_ingame","items/cropped/regalia_grip_standard_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_grand_prism_inventory","items/inventory/regalia_grip_grand_prism.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_grip_grand_prism_ingame","items/cropped/regalia_grip_grand_prism.png",1,0,0,0);

-- Hidden required barrel core used for muzzle-device positioning.
SpriteLoad("wz_ddb_regalia_barrel_core_inventory","items/internal/regalia_barrel_core.png",1,0,0,0);
SpriteLoad("wz_ddb_regalia_barrel_core_ingame","items/internal/regalia_barrel_core.png",1,0,0,0);

SpriteLoad("wz_ddb_regalia_front_compact_inventory","items/inventory/regalia_front_compact.png",1,0,0,0);
