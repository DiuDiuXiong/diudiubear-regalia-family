-- --------------------------------------------------------------------------
-- Original-colour stocks: larger parts provide larger bonuses.
-- --------------------------------------------------------------------------
WeaponModCreate("wz_ddb_regalia_stock_compact","stock",0,0,2,-3,0,false,["wz_ddb_regalia","wz_ddb_regalia_prism"]);
ItemSetName("wz_ddb_regalia_stock_compact","Regalia Stock - Compact");
ItemSetDescription("wz_ddb_regalia_stock_compact","A light Regalia stock. Small recoil and handling improvement.");
ItemSetSpriteInventory("wz_ddb_regalia_stock_compact","wz_ddb_regalia_stock_compact_inventory");
ItemSetSpriteIngame("wz_ddb_regalia_stock_compact","wz_ddb_regalia_stock_compact_ingame");
ItemSetPriceValue("wz_ddb_regalia_stock_compact",18000);
ItemSetWeight("wz_ddb_regalia_stock_compact",0.25);
ItemSetStackLimit("wz_ddb_regalia_stock_compact",1);

WeaponModCreate("wz_ddb_regalia_stock_standard","stock",0,0,4,-7,0,false,["wz_ddb_regalia","wz_ddb_regalia_prism"]);
ItemSetName("wz_ddb_regalia_stock_standard","Regalia Stock - Standard");
ItemSetDescription("wz_ddb_regalia_stock_standard","A balanced Regalia stock with strong recoil control and improved ergonomics.");
ItemSetSpriteInventory("wz_ddb_regalia_stock_standard","wz_ddb_regalia_stock_standard_inventory");
ItemSetSpriteIngame("wz_ddb_regalia_stock_standard","wz_ddb_regalia_stock_standard_ingame");
ItemSetPriceValue("wz_ddb_regalia_stock_standard",35000);
ItemSetWeight("wz_ddb_regalia_stock_standard",0.40);
ItemSetStackLimit("wz_ddb_regalia_stock_standard",1);

WeaponModCreate("wz_ddb_regalia_stock_grand","stock",0,0,7,-12,0,false,["wz_ddb_regalia","wz_ddb_regalia_prism"]);
ItemSetName("wz_ddb_regalia_stock_grand","Regalia Stock - Grand");
ItemSetDescription("wz_ddb_regalia_stock_grand","The largest original Regalia stock. Excellent recoil control and handling at additional weight.");
ItemSetSpriteInventory("wz_ddb_regalia_stock_grand","wz_ddb_regalia_stock_grand_inventory");
