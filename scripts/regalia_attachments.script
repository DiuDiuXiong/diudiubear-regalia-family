ItemSetDescription("wz_ddb_regalia_front_compact","A compact Regalia muzzle brake with a small damage and recoil-control bonus. Fits only Regalia-family receivers.");
ItemSetSpriteInventory("wz_ddb_regalia_front_compact","wz_ddb_regalia_front_compact_inventory");
